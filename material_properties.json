{
  "title": "Material Properties",
  "description": "Material properties indexed by IGSN with version tracking",
  "type": "object",
  "properties": {
    "Sample_ID": {
          "type": "string",
          "title": "Sample_ID",
          "description": "Lookup for the IGSN of the sample",
          "format": "autocomplete",
          "options": {
            "autocomplete": {
              "search": "search_deposition",
              "renderResult": "render_deposition",
              "getResultValue": "get_deposition_value",
              "autoSelect": true,
              "debounceTime": 500
            }
          }
      },
    "materialType": {
      "type": "string",
      "title": "Material Type",
      "description": "Type or classification of the material"
    },
    "materialThickness": {
      "type": "number",
      "title": "Material Thickness",
      "description": "in mm"
    },
    "density": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "title": "Density",
      "description": "in kg/m³"
    },
    "bulkWaveSpeed": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "title": "Bulk Wave Speed (C0)",
      "description": "in m/s"
    },
    "longitudinalWaveSpeed": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "title": "Longitudinal Wave Speed (C_L)",
      "description": "in m/s"
    },
    "source": {
      "type": "string",
      "title": "Source",
      "description": "Citation, reference, or source of this data"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": ["Sample_ID", "source"]
}

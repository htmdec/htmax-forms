{
  "title": "Material Properties",
  "description": "Material properties indexed by IGSN with version tracking",
  "type": "object",
  "properties": {
    "IGSN": {
          "type": "string",
          "title": "IGSN",
          "description": "Lookup for the IGSN of the sample",
          "format": "autocomplete",
          "options": {
            "autocomplete": {
              "search": "search_deposition",
              "renderResult": "render_deposition",
              "getResultValue": "get_deposition_value",
              "autoSelect": true,
              "debounceTime": 500
            }
          },
          "propertyOrder": 0
      },
    "materialType": {
      "type": "string",
      "title": "Material Type",
      "description": "Type or classification of the material",
      "propertyOrder": 1
    },
    "materialThickness": {
      "type": "number",
      "title": "Material Thickness",
      "description": "in mm",
      "propertyOrder": 2
    },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "density": {
            "type": "object",
            "title": "Density",
            "description": "in kg/m³",
            "properties": {
              "value": {
                "type": "number",
                "title": "Value",
                "description": "in kg/m³",
                "minimum": 1,
                "propertyOrder": 0
              },
              "source": {
                "type": "string",
                "title": "Source",
                "description": "Citation, reference, or source of this value",
                "propertyOrder": 1
              }
            },
            "required": ["value", "source"]
          },
          "c0": {
            "type": "object",
            "title": "Bulk Wave Speed (C0)",
            "description": "in m/s",
            "properties": {
              "value": {
                "type": "number",
                "title": "Value",
                "description": "in m/s",
                "minimum": 1,
                "propertyOrder": 0
              },
              "source": {
                "type": "string",
                "title": "Source",
                "description": "Citation, reference, or source of this value",
                "propertyOrder": 1
              }
            },
            "required": ["value", "source"]
          },
          "c_l": {
            "type": "object",
            "title": "Longitudinal Wave Speed (C_L)",
            "description": "in m/s",
            "properties": {
              "value": {
                "type": "number",
                "title": "Value",
                "description": "in m/s",
                "minimum": 1,
                "propertyOrder": 0
              },
              "source": {
                "type": "string",
                "title": "Source",
                "description": "Citation, reference, or source of this value",
                "propertyOrder": 1
              }
            },
            "required": ["value", "source"]
          }
        }
      },
      "title": "Measurements",
      "description": "Array of measurement sets containing density, bulk wave speed, and longitudinal wave speed",
      "propertyOrder": 3
    },
    "notes": {
      "type": "string",
      "title": "Notes",
      "propertyOrder": 4
    }
  },
  "required": ["IGSN", "measurements"]
}

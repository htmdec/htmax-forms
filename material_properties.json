{
  "title": "Material Properties",
  "description": "Material properties indexed by IGSN with version tracking",
  "type": "object",
  "properties": {
    "Sample_ID": {
          "type": "string",
          "title": "Sample_ID",
          "description": "Lookup for the IGSN of the sample",
          "format": "autocomplete",
          "options": {
            "autocomplete": {
              "search": "search_deposition",
              "renderResult": "render_deposition",
              "getResultValue": "get_deposition_value",
              "autoSelect": true,
              "debounceTime": 500
            }
          },
          "propertyOrder": 0
      },
    "materialType": {
      "type": "string",
      "title": "Material Type",
      "description": "Type or classification of the material",
      "propertyOrder": 1
    },
    "materialThickness": {
      "type": "number",
      "title": "Material Thickness",
      "description": "in mm",
      "propertyOrder": 2
    },
    "density": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "title": "Value",
            "description": "in kg/m³",
            "minimum": 1
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Citation, reference, or source of this value"
          }
        },
        "required": ["value", "source"]
      },
      "title": "Density",
      "description": "in kg/m³",
      "propertyOrder": 3
    },
    "bulkWaveSpeed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "title": "Value",
            "description": "in m/s",
            "minimum": 1
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Citation, reference, or source of this value"
          }
        },
        "required": ["value", "source"]
      },
      "title": "Bulk Wave Speed (C0)",
      "description": "in m/s",
      "propertyOrder": 4
    },
    "longitudinalWaveSpeed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "title": "Value",
            "description": "in m/s",
            "minimum": 1
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Citation, reference, or source of this value"
          }
        },
        "required": ["value", "source"]
      },
      "title": "Longitudinal Wave Speed (C_L)",
      "description": "in m/s",
      "propertyOrder": 5
    },
    "notes": {
      "type": "string",
      "title": "Notes",
      "propertyOrder": 6
    }
  },
  "required": ["Sample_ID", "density", "bulkWaveSpeed", "longitudinalWaveSpeed"]
}

{
  "title": "Material Properties",
  "description": "Material properties indexed by IGSN with version tracking",
  "type": "object",
  "properties": {
    "Sample_ID": {
          "type": "string",
          "title": "Sample_ID",
          "description": "Lookup for the IGSN of the sample",
          "format": "autocomplete",
          "options": {
            "autocomplete": {
              "search": "search_deposition",
              "renderResult": "render_deposition",
              "getResultValue": "get_deposition_value",
              "autoSelect": true,
              "debounceTime": 500
            }
          }
      },
    "version": {
      "type": "integer",
      "title": "Version",
      "description": "Version number for this IGSN's properties",
      "minimum": 1,
      "default": 1
    },
    "igsn_version": {
      "type": "string",
      "title": "IGSN Version",
      "description": "Unique identifier combining IGSN and version",
      "readonly": true,
      "template": "{{Sample_ID}}_v{{version}}",
      "options": {
        "hidden": true
      }
    },
    "density": {
      "type": "number",
      "title": "Density",
      "description": "in kg/m³"
    },
    "bulkWaveSpeed": {
      "type": "number",
      "title": "Bulk Wave Speed (C0)",
      "description": "in m/s"
    },
    "longitudinalWaveSpeed": {
      "type": "number",
      "title": "Longitudinal Wave Speed (C_L)",
      "description": "in m/s"
    },
    "source": {
      "type": "string",
      "title": "Source",
      "description": "Citation, reference, or source of this data"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": ["igsn", "version", "source"]
}

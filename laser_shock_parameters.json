{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Laser Shock Experiment Parameters",
    "description": "This form is designed to capture detailed metadata for laser-driven flyer plate experiments. Each entry corresponds to a single shot.",
    "type": "object",
    "properties": {
        "Timestamp": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time",
            "title": "Timestamp",
            "propertyOrder": 1
        },
        "Exp_ID": {
            "type": [
                "number",
                "null"
            ],
            "title": "Exp_ID",
            "propertyOrder": 2
        },
        "Exp_type": {
            "type": [
                "string",
                "null"
            ],
            "title": "Exp_type",
            "propertyOrder": 3
        },
        "Flyer_ID": {
            "type": [
                "string",
                "null"
            ],
            "title": "Flyer_ID",
            "propertyOrder": 4
        },
        "Flyer_material": {
            "type": [
                "string",
                "null"
            ],
            "title": "Flyer_material",
            "propertyOrder": 5
        },
        "Flyer_Thickness_um": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_Thickness (um)",
            "propertyOrder": 6
        },
        "sample_IGSN": {
            "type": [
                "string",
                "null"
            ],
            "title": "sample_IGSN",
            "description": "Lookup for the IGSN of the sample",
            "format": "autocomplete",
            "options": {
                "autocomplete": {
                    "search": "search_deposition",
                    "renderResult": "render_deposition",
                    "getResultValue": "get_deposition_value",
                    "autoSelect": true,
                    "debounceTime": 500
                }
            },
            "propertyOrder": 7
        },
        "Sample_material": {
            "type": [
                "string",
                "null"
            ],
            "title": "Sample material",
            "propertyOrder": 8
        },
        "Spacing_um": {
            "type": [
                "number",
                "null"
            ],
            "title": "Spacing (um)",
            "propertyOrder": 9
        },
        "Waveplate_Angle_Degrees": {
            "type": [
                "number",
                "null"
            ],
            "title": "Waveplate_Angle (Degrees)",
            "propertyOrder": 10
        },
        "PDV_FileName": {
            "type": [
                "string",
                "null"
            ],
            "title": "PDV_FileName",
            "pattern": "^[^\\s]+$",
            "propertyOrder": 11
        },
        "PDV_Target_Wavelength_m": {
            "type": [
                "number",
                "null"
            ],
            "title": "PDV_Target_Wavelength (m)",
            "propertyOrder": 12
        },
        "PDV_Target_Power_dBm": {
            "type": [
                "number",
                "null"
            ],
            "title": "PDV_Target_Power (dBm)",
            "propertyOrder": 13
        },
        "PDV_Ref_Wavelength_m": {
            "type": [
                "number",
                "null"
            ],
            "title": "PDV_Ref_Wavelength (m)",
            "propertyOrder": 14
        },
        "PDV_Ref_Power_dBm": {
            "type": [
                "number",
                "null"
            ],
            "title": "PDV_Ref_Power (dBm)",
            "propertyOrder": 15
        },
        "PDV_Return_Power_dBm": {
            "type": [
                "number",
                "null"
            ],
            "title": "PDV_Return_Power (dBm)",
            "propertyOrder": 16
        },
        "Flyer_Row": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_Row",
            "propertyOrder": 17
        },
        "Flyer_Column": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_Column",
            "propertyOrder": 18
        },
        "Flyer_X_Position_Desired_mm": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_X_Position_Desired (mm)",
            "propertyOrder": 19
        },
        "Flyer_Y_Position_Desired_mm": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_Y_Position_Desired (mm)",
            "propertyOrder": 20
        },
        "Flyer_X_Position_Final_mm": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_X_Position_Final (mm)",
            "propertyOrder": 21
        },
        "Flyer_Y_Position_Final_mm": {
            "type": [
                "number",
                "null"
            ],
            "title": "Flyer_Y_Position_Final (mm)",
            "propertyOrder": 22
        },
        "Laser_Ref_Energy_mJ": {
            "type": [
                "number",
                "null"
            ],
            "title": "Laser_Ref_Energy (mJ)",
            "propertyOrder": 23
        },
        "Laser_Target_Energy_mJ": {
            "type": [
                "number",
                "null"
            ],
            "title": "Laser_Target_Energy (mJ)",
            "propertyOrder": 24
        },
        "Beam_Profile_FileName": {
            "type": [
                "string",
                "null"
            ],
            "title": "Beam_Profile_FileName",
            "propertyOrder": 25
        },
        "Shot_Time_seconds": {
            "type": [
                "number",
                "null"
            ],
            "title": "Shot_Time (seconds)",
            "propertyOrder": 26
        },
        "Notes": {
            "type": [
                "string",
                "null"
            ],
            "title": "Notes",
            "propertyOrder": 27
        },
        "Performed_by": {
            "type": [
                "string",
                "null"
            ],
            "title": "Performed_by",
            "propertyOrder": 28
        },
        "Grant": {
            "type": [
                "string",
                "null"
            ],
            "title": "Grant",
            "propertyOrder": 29
        },
        "Location": {
            "type": [
                "string",
                "null"
            ],
            "title": "Location",
            "propertyOrder": 30
        }
    },
    "required": [
        "Timestamp",
        "Exp_ID",
        "Exp_type",
        "Flyer_ID",
        "Flyer_material",
        "Flyer_Thickness_um",
        "sample_IGSN",
        "Sample_material",
        "Spacing_um",
        "Waveplate_Angle_Degrees",
        "PDV_FileName",
        "PDV_Target_Wavelength_m",
        "PDV_Target_Power_dBm",
        "PDV_Ref_Wavelength_m",
        "PDV_Ref_Power_dBm",
        "PDV_Return_Power_dBm",
        "Flyer_Row",
        "Flyer_Column",
        "Flyer_X_Position_Desired_mm",
        "Flyer_Y_Position_Desired_mm",
        "Flyer_X_Position_Final_mm",
        "Flyer_Y_Position_Final_mm",
        "Laser_Ref_Energy_mJ",
        "Laser_Target_Energy_mJ",
        "Beam_Profile_FileName",
        "Shot_Time_seconds",
        "Notes",
        "Performed_by",
        "Grant",
        "Location"
    ],
    "additionalProperties": true
}
{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ALPSS Result Schema",
    "type": "object",
    "properties": {
        "File Name": {
            "type": "string",
            "propertyOrder": 1
        },
        "Sample_IGSN": {
            "type": [
                "string",
                "null"
            ],
            "description": "Lookup for the IGSN of the sample",
            "format": "autocomplete",
            "options": {
                "autocomplete": {
                    "search": "search_deposition",
                    "renderResult": "render_deposition",
                    "getResultValue": "get_deposition_value",
                    "autoSelect": true,
                    "debounceTime": 500
                }
            },
            "propertyOrder": 2
        },
        "Run Time": {
            "type": "number",
            "propertyOrder": 3
        },
        "Velocity at Max Compression": {
            "type": "number",
            "propertyOrder": 4
        },
        "Time at Max Compression": {
            "type": "number",
            "propertyOrder": 5
        },
        "Velocity at Max Tension": {
            "type": "number",
            "propertyOrder": 6
        },
        "Time at Max Tension": {
            "type": "number",
            "propertyOrder": 7
        },
        "Velocity at Recompression": {
            "type": "number",
            "propertyOrder": 8
        },
        "Time at Recompression": {
            "type": "number",
            "propertyOrder": 9
        },
        "Carrier Frequency": {
            "type": "number",
            "propertyOrder": 10
        },
        "Spall Strength": {
            "type": "number",
            "propertyOrder": 11
        },
        "Spall Strength Uncertainty": {
            "type": "number",
            "propertyOrder": 12
        },
        "Strain Rate": {
            "type": "number",
            "propertyOrder": 13
        },
        "Strain Rate Uncertainty": {
            "type": "number",
            "propertyOrder": 14
        },
        "Peak Shock Stress": {
            "type": "number",
            "propertyOrder": 15
        },
        "Spect Time Res": {
            "type": "number",
            "propertyOrder": 16
        },
        "Spect Freq Res": {
            "type": "number",
            "propertyOrder": 17
        },
        "Spect Velocity Res": {
            "type": "number",
            "propertyOrder": 18
        },
        "Signal Start Time": {
            "type": "number",
            "propertyOrder": 19
        },
        "Smoothing Characteristic Time": {
            "type": "number",
            "propertyOrder": 20
        },
        "Version": {
            "type": "string",
            "propertyOrder": 21
        }
    },
    "required": [
        "File Name",
        "Run Time",
        "Velocity at Max Compression",
        "Time at Max Compression",
        "Velocity at Max Tension",
        "Time at Max Tension",
        "Velocity at Recompression",
        "Time at Recompression",
        "Carrier Frequency",
        "Spall Strength",
        "Spall Strength Uncertainty",
        "Strain Rate",
        "Strain Rate Uncertainty",
        "Peak Shock Stress",
        "Spect Time Res",
        "Spect Freq Res",
        "Spect Velocity Res",
        "Signal Start Time",
        "Smoothing Characteristic Time",
        "Version"
    ]
}
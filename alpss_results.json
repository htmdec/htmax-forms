{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ALPSS Result Schema",
    "type": "object",
    "properties": {
        "date": {
            "type": "string",
            "title": "Date",
            "propertyOrder": 1
        },
        "time": {
            "type": "string",
            "title": "Time",
            "propertyOrder": 2
        },
        "file_name": {
            "type": "string",
            "title": "File Name",
            "propertyOrder": 3
        },
        "Sample_IGSN": {
            "type": [
                "string",
                "null"
            ],
            "title": "Sample_IGSN",
            "description": "Lookup for the IGSN of the sample",
            "format": "autocomplete",
            "options": {
                "autocomplete": {
                    "search": "search_deposition",
                    "renderResult": "render_deposition",
                    "getResultValue": "get_deposition_value",
                    "autoSelect": true,
                    "debounceTime": 500
                }
            },
            "propertyOrder": 4
        },
        "run_time": {
            "type": "number",
            "title": "Run Time",
            "propertyOrder": 5
        },
        "velocity_at_max_compression": {
            "type": "number",
            "title": "Velocity at Max Compression",
            "propertyOrder": 6
        },
        "time_at_max_compression": {
            "type": "number",
            "title": "Time at Max Compression",
            "propertyOrder": 7
        },
        "velocity_at_max_tension": {
            "type": "number",
            "title": "Velocity at Max Tension",
            "propertyOrder": 8
        },
        "time_at_max_tension": {
            "type": "number",
            "title": "Time at Max Tension",
            "propertyOrder": 9
        },
        "velocity_at_recompression": {
            "type": "number",
            "title": "Velocity at Recompression",
            "propertyOrder": 10
        },
        "time_at_recompression": {
            "type": "number",
            "title": "Time at Recompression",
            "propertyOrder": 11
        },
        "carrier_frequency": {
            "type": "number",
            "title": "Carrier Frequency",
            "propertyOrder": 12
        },
        "spall_strength": {
            "type": "number",
            "title": "Spall Strength",
            "propertyOrder": 13
        },
        "spall_strength_uncertainty": {
            "type": "number",
            "title": "Spall Strength Uncertainty",
            "propertyOrder": 14
        },
        "strain_rate": {
            "type": "number",
            "title": "Strain Rate",
            "propertyOrder": 15
        },
        "strain_rate_uncertainty": {
            "type": "number",
            "title": "Strain Rate Uncertainty",
            "propertyOrder": 16
        },
        "peak_shock_stress": {
            "type": "number",
            "title": "Peak Shock Stress",
            "propertyOrder": 17
        },
        "spect_time_res": {
            "type": "number",
            "title": "Spect Time Res",
            "propertyOrder": 18
        },
        "spect_freq_res": {
            "type": "number",
            "title": "Spect Freq Res",
            "propertyOrder": 19
        },
        "spect_velocity_res": {
            "type": "number",
            "title": "Spect Velocity Res",
            "propertyOrder": 20
        },
        "signal_start_time": {
            "type": "number",
            "title": "Signal Start Time",
            "propertyOrder": 21
        },
        "smoothing_characteristic_time": {
            "type": "number",
            "title": "Smoothing Characteristic Time",
            "propertyOrder": 22
        }
    },
    "required": [
        "file_name",
        "run_time",
        "velocity_at_max_compression",
        "time_at_max_compression",
        "velocity_at_max_tension",
        "time_at_max_tension",
        "velocity_at_recompression",
        "time_at_recompression",
        "carrier_frequency",
        "spall_strength",
        "spall_strength_uncertainty",
        "strain_rate",
        "strain_rate_uncertainty",
        "peak_shock_stress",
        "spect_time_res",
        "spect_freq_res",
        "spect_velocity_res",
        "signal_start_time",
        "smoothing_characteristic_time"
    ]
}
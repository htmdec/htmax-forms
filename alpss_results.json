{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ALPSS Result Schema",
    "type": "object",
    "properties": {
        "file_name": {
            "type": "string",
            "propertyOrder": 1,
            "title": "File Name"
        },
        "Sample_IGSN": {
            "type": [
                "string",
                "null"
            ],
            "description": "Lookup for the IGSN of the sample",
            "format": "autocomplete",
            "options": {
                "autocomplete": {
                    "search": "search_deposition",
                    "renderResult": "render_deposition",
                    "getResultValue": "get_deposition_value",
                    "autoSelect": true,
                    "debounceTime": 500
                }
            },
            "propertyOrder": 2,
            "title": "Sample_IGSN"
        },
        "run_time": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 3,
            "title": "Run Time"
        },
        "velocity_at_max_compression": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 4,
            "title": "Velocity at Max Compression"
        },
        "time_at_max_compression": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 5,
            "title": "Time at Max Compression"
        },
        "velocity_at_max_tension": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 6,
            "title": "Velocity at Max Tension"
        },
        "time_at_max_tension": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 7,
            "title": "Time at Max Tension"
        },
        "velocity_at_recompression": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 8,
            "title": "Velocity at Recompression"
        },
        "time_at_recompression": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 9,
            "title": "Time at Recompression"
        },
        "carrier_frequency": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 10,
            "title": "Carrier Frequency"
        },
        "spall_strength": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 11,
            "title": "Spall Strength"
        },
        "spall_strength_uncertainty": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 12,
            "title": "Spall Strength Uncertainty"
        },
        "strain_rate": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 13,
            "title": "Strain Rate"
        },
        "strain_rate_uncertainty": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 14,
            "title": "Strain Rate Uncertainty"
        },
        "peak_shock_stress": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 15,
            "title": "Peak Shock Stress"
        },
        "spect_time_res": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 16,
            "title": "Spect Time Res"
        },
        "spect_freq_res": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 17,
            "title": "Spect Freq Res"
        },
        "spect_velocity_res": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 18,
            "title": "Spect Velocity Res"
        },
        "signal_start_time": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 19,
            "title": "Signal Start Time"
        },
        "smoothing_characteristic_time": {
            "type": [
                "number",
                "null"
            ],
            "propertyOrder": 20,
            "title": "Smoothing Characteristic Time"
        },
        "version": {
            "type": "string",
            "propertyOrder": 21,
            "title": "Version"
        }
    },
    "required": [
        "file_name",
        "run_time",
        "velocity_at_max_compression",
        "time_at_max_compression",
        "velocity_at_max_tension",
        "time_at_max_tension",
        "velocity_at_recompression",
        "time_at_recompression",
        "carrier_frequency",
        "spall_strength",
        "spall_strength_uncertainty",
        "strain_rate",
        "strain_rate_uncertainty",
        "peak_shock_stress",
        "spect_time_res",
        "spect_freq_res",
        "spect_velocity_res",
        "signal_start_time",
        "smoothing_characteristic_time",
        "version"
    ]
}